{
    "name": "argumentor/app",
    "description": "ArguMentor — AI 토론면접 시뮬레이션 시스템 (Vanilla PHP SSR + MySQL + DeepSeek)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public public/index.php"
    }
}
